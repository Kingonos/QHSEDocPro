{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "User account information and preferences.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique user ID from Firebase Auth." },
        "email": { "type": "string", "format": "email", "description": "User's email address." },
        "displayName": { "type": "string", "description": "User's display name." },
        "photoURL": { "type": "string", "format": "uri", "description": "User's profile picture URL." },
        "role": { "type": "string", "enum": ["user", "admin"], "description": "User's role in the system." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the profile was created." }
      },
      "required": ["uid", "email", "role"]
    },
    "Document": {
      "title": "Generated Document",
      "description": "A document generated by the QHSE or SOP tool.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique document ID." },
        "ownerId": { "type": "string", "description": "UID of the user who owns this document." },
        "title": { "type": "string", "description": "Title of the document." },
        "type": { "type": "string", "enum": ["HSE Plan", "HSE Policy", "Risk Assessment", "JHA", "SWMS", "SOP", "Emergency Response", "Environmental Management", "Quality Management", "Checklist", "Incident Report", "Toolbox Talk", "Permit to Work"], "description": "The category of the document." },
        "content": { "type": "string", "description": "The full text content of the document (Markdown)." },
        "metadata": { "type": "object", "description": "Specific details used to generate the document (e.g., company name, hazards)." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the document was generated." },
        "updatedAt": { "type": "string", "format": "date-time", "description": "When the document was last edited." }
      },
      "required": ["ownerId", "title", "type", "content"]
    },
    "Project": {
      "title": "School Project",
      "description": "An academic project write-up.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique project ID." },
        "ownerId": { "type": "string", "description": "UID of the user who owns this project." },
        "topic": { "type": "string", "description": "The topic of the school project." },
        "level": { "type": "string", "enum": ["ND", "HND", "BSc", "MSc"], "description": "Academic level." },
        "chapters": { "type": "object", "description": "The content of each chapter." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the project was generated." }
      },
      "required": ["ownerId", "topic", "level", "chapters"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "UserProfile",
      "description": "Individual user profiles."
    },
    "/documents/{docId}": {
      "schema": "Document",
      "description": "A collection of generated QHSE documents."
    },
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "A collection of academic project write-ups."
    }
  }
}
