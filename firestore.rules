rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {uid}
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - displayName: string (optional)
    //   - photoURL: string (optional)
    //   - role: string (required, enum: ['user', 'admin'])
    //   - permissions: list (optional)
    //   - createdAt: timestamp (required)
    //
    // Collection: documents
    // Document ID: {docId}
    // Fields:
    //   - ownerId: string (required)
    //   - title: string (required)
    //   - type: string (required)
    //   - content: string (required)
    //   - metadata: map (optional)
    //   - createdAt: timestamp (required)
    //   - updatedAt: timestamp (required)
    //
    // Collection: documents/{docId}/versions
    // Document ID: {versionId}
    // Fields:
    //   - content: string (required)
    //   - createdAt: timestamp (required)
    //   - createdBy: string (required)
    //
    // Collection: projects
    // Document ID: {projectId}
    // Fields:
    //   - ownerId: string (required)
    //   - topic: string (required)
    //   - level: string (required)
    //   - chapters: map (required)
    //   - createdAt: timestamp (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.ownerId;
    }

    function isParentDocOwner(docId) {
      return isAuthenticated() && request.auth.uid == get(/databases/$(database)/documents/documents/$(docId)).data.ownerId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "micheal.onos@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role', 'createdAt']) &&
             data.uid is string &&
             data.email is string &&
             data.role in ['user', 'admin'] &&
             (!('permissions' in data) || data.permissions is list) &&
             data.createdAt is timestamp;
    }

    function isValidDocument(data) {
      return data.keys().hasAll(['ownerId', 'title', 'type', 'content', 'createdAt', 'updatedAt']) &&
             data.ownerId == request.auth.uid &&
             data.title is string && data.title.size() < 200 &&
             data.type is string &&
             data.content is string && data.content.size() < 1000000 &&
             data.createdAt is timestamp &&
             data.updatedAt is timestamp;
    }

    function isValidProject(data) {
      return data.keys().hasAll(['ownerId', 'topic', 'level', 'chapters', 'createdAt']) &&
             data.ownerId == request.auth.uid &&
             data.topic is string && data.topic.size() < 500 &&
             data.level in ['ND', 'HND', 'BSc', 'MSc'] &&
             data.chapters is map &&
             data.createdAt is timestamp;
    }

    function isValidDocumentVersion(data) {
      return data.keys().hasAll(['content', 'createdAt', 'createdBy']) &&
             data.content is string && data.content.size() < 1000000 &&
             data.createdAt is timestamp &&
             data.createdBy == request.auth.uid;
    }

    function isValidMail(data) {
      return data.keys().hasAll(['to', 'message']) &&
             data.to is string && data.to.size() < 200 &&
             data.message is map &&
             data.message.keys().hasAll(['subject', 'text', 'html']) &&
             data.message.subject is string && data.message.subject.size() < 200 &&
             data.message.text is string && data.message.text.size() < 1000000 &&
             data.message.html is string && data.message.html.size() < 1000000;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /mail/{messageId} {
      allow create: if isAuthenticated() && isValidMail(request.resource.data);
      allow read, update, delete: if false; // Only extension should read/update
    }

    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow create: if isOwner(uid) && isValidUser(request.resource.data) && request.resource.data.role == 'user';
      allow update: if (isOwner(uid) && isValidUser(request.resource.data) && request.resource.data.role == resource.data.role) || isAdmin();
    }

    match /documents/{docId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isAuthenticated() && isValidDocument(request.resource.data);
      allow update: if isDocOwner() && isValidDocument(request.resource.data);
      allow delete: if isDocOwner() || isAdmin();

      match /versions/{versionId} {
        allow read: if isParentDocOwner(docId) || isAdmin();
        allow create: if isParentDocOwner(docId) && isValidDocumentVersion(request.resource.data);
      }
    }

    match /projects/{projectId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isAuthenticated() && isValidProject(request.resource.data);
      allow update: if isDocOwner() && isValidProject(request.resource.data);
      allow delete: if isDocOwner() || isAdmin();
    }
  }
}
